FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./
COPY shared/package*.json ./shared/
COPY frontend/package*.json ./frontend/
COPY backend/package*.json ./backend/

# Build shared package once on startup
# npm ci runs at container start (after named volumes are mounted) so node_modules stay current
ENTRYPOINT ["/bin/sh", "-c"]
CMD ["npm ci --prefer-offline --no-audit --no-update-notifier && npm run build:shared && npm run dev"]
